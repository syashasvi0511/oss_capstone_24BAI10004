#!/bin/bash
# Script 5: Open Source Manifesto Generator
# Author: Yashasvi Sharma

# Tip: You can create an alias like:
# alias manifesto='./script5.sh'

echo "Answer three questions to generate your manifesto."
echo ""

# --- User input ---
read -p "1. Name one open-source tool you use every day: " TOOL
read -p "2. In one word, what does 'freedom' mean to you? " FREEDOM
read -p "3. Name one thing you would build and share freely: " BUILD

# --- Variables ---
DATE=$(date '+%d %B %Y')
OUTPUT="manifesto_$(whoami).txt"

# --- Create manifesto ---
echo "----------------------------------------" > "$OUTPUT"
echo "Open Source Manifesto" >> "$OUTPUT"
echo "Date: $DATE" >> "$OUTPUT"
echo "----------------------------------------" >> "$OUTPUT"
echo "" >> "$OUTPUT"

echo "I believe in the power of open source. Using tools like $TOOL every day, I understand the importance of collaboration and transparency. To me, freedom means $FREEDOM, and I am inspired to contribute back to the community. I would love to build $BUILD and share it freely so others can learn, improve, and benefit from it." >> "$OUTPUT"

echo "" >> "$OUTPUT"
echo "----------------------------------------" >> "$OUTPUT"

# --- Output result ---
echo ""
echo "Manifesto saved to $OUTPUT"
echo ""

# --- Display file ---
cat "$OUTPUT"
